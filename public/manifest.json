{
  "manifest_version": 3,
  "name": "GTAB - Kişiselleştirilebilir Başlangıç Sayfası",
  "version": "1.1.8",
  "description": "Kendi kişiselleştirilebilir yeni sekme sayfanız. Kısayollar, görevler, arama ve daha fazlası.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GTab",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "tabs"
  ]
}
